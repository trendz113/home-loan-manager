# URL of your deployed Home Loan Manager Railway service (no trailing slash)
APP_URL=https://web-production-xxxx.up.railway.app

# Must match the ADMIN_TOKEN env var set on the Railway service
ADMIN_TOKEN=change-this-to-a-long-random-string

# Optional — where dated backups are saved (defaults to ./backups)
BACKUP_DIR=./backups

# Optional — how many days of backups to keep (defaults to 90)
KEEP_LAST_N=90
