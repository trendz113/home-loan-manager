# Razorpay (get live keys from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Path to the Excel file leads get appended to.
# On Railway, point this at a mounted Volume (e.g. /data/leads.xlsx) so leads
# survive redeploys — a path with no volume attached will lose data on restart.
LEADS_FILE_PATH=/data/leads.xlsx

# Secret token to protect the /admin/leads?token=... download route.
# Generate something long and random, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=change-this-to-a-long-random-string

# Optional — price of the paid report in paise. Defaults to 14900 (₹149) if unset.
REPORT_PRICE_PAISE=14900
